<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/month_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="14dp"
        android:paddingBottom="12dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:id="@+id/month_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="2026&#x5E74;5&#x6708;"
            android:textColor="@android:color/black"
            android:textSize="22sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/view_mode_switch"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/calendar_mode_switch_bg"
            android:orientation="horizontal"
            android:padding="3dp">

            <TextView
                android:id="@+id/button_week_mode"
                android:layout_width="72dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="&#x5468;"
                android:textColor="#202124"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/button_month_mode"
                android:layout_width="72dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="&#x6708;"
                android:textColor="#5F6368"
                android:textSize="15sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/week_header"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:background="#FFFFFF"
        android:orientation="horizontal">

        <TextView
            style="@style/CalendarWeekHeaderCell"
            android:text="&#x5468;&#x4E00;" />

        <TextView
            style="@style/CalendarWeekHeaderCell"
            android:text="&#x5468;&#x4E8C;" />

        <TextView
            style="@style/CalendarWeekHeaderCell"
            android:text="&#x5468;&#x4E09;" />

        <TextView
            style="@style/CalendarWeekHeaderCell"
            android:text="&#x5468;&#x56DB;" />

        <TextView
            style="@style/CalendarWeekHeaderCell"
            android:text="&#x5468;&#x4E94;" />

        <TextView
            style="@style/CalendarWeekHeaderCell"
            android:text="&#x5468;&#x516D;" />

        <TextView
            style="@style/CalendarWeekHeaderCell"
            android:text="&#x5468;&#x65E5;" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/calendar_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF">

        <LinearLayout
            android:id="@+id/week_mode_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#FFFFFF"
            android:orientation="vertical">

            <HorizontalScrollView
                android:id="@+id/week_date_horizontal_scroll"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:fillViewport="false"
                android:overScrollMode="never"
                android:scrollbars="none">

                <com.example.imageview.WeekDateBarView
                    android:id="@+id/week_date_bar"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent" />
            </HorizontalScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal">

                <com.example.imageview.WeekTimeAxisView
                    android:id="@+id/week_time_axis"
                    android:layout_width="56dp"
                    android:layout_height="match_parent" />

                <HorizontalScrollView
                    android:id="@+id/week_task_horizontal_scroll"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:fillViewport="false"
                    android:overScrollMode="never"
                    android:scrollbars="none">

                    <com.example.imageview.ObservableScrollView
                        android:id="@+id/week_vertical_scroll"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:fillViewport="false"
                        android:overScrollMode="never"
                        android:scrollbars="none">

                        <com.example.imageview.WeekTaskGridView
                            android:id="@+id/week_task_grid"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </com.example.imageview.ObservableScrollView>
                </HorizontalScrollView>
            </LinearLayout>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/calendar_grid"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#FFFFFF"
            android:overScrollMode="never"
            android:visibility="gone" />
    </FrameLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:layout_gravity="bottom"
        android:background="#F6EFEE"
        app:menu="@menu/bottom_navigation_menu" />

</LinearLayout>
